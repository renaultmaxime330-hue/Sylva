# Copier ce fichier en .env.local et remplir les valeurs réelles.
# .env.local n'est jamais commité (voir .gitignore).

# Chaîne de connexion PostgreSQL fournie par Railway (onglet "Connect" du service Postgres).
DATABASE_URL=postgresql://user:password@host:port/database

# Secrets de signature des jetons — deux chaînes aléatoires longues et DIFFÉRENTES l'une de l'autre.
# Générer avec : openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

NODE_ENV=development
PORT=3000

# Notifications push (Web Push / VAPID) — générer avec :
# node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@example.com
